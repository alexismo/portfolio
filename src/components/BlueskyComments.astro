---
interface Props {
  postUri: string;
}

const { postUri } = Astro.props;

const [did, , rkey] = postUri.replace("at://", "").split("/");
const bskyUrl = `https://bsky.app/profile/${did}/post/${rkey}`;
---

<div class="bsky-thread" data-post-uri={postUri}>
  <p class="bsky-loading">Loading comments…</p>
</div>
<a
  href={bskyUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="bsky-reply-link"
>
  Reply on Bluesky
</a>

<script>
  function initBlueskyComments() {
    const threads = document.querySelectorAll<HTMLElement>(
      ".bsky-thread[data-post-uri]",
    );
    threads.forEach(async (thread) => {
      const postUri = thread.dataset.postUri;
      if (!postUri) return;

      try {
        const res = await fetch(
          `https://public.api.bsky.app/xrpc/app.bsky.feed.getPostThread?uri=${encodeURIComponent(postUri)}&depth=5`,
        );
        const data = await res.json();
        const replies = data.thread?.replies ?? [];
        if (replies.length === 0) {
          thread.innerHTML = '<p class="bsky-empty">No comments yet.</p>';
          return;
        }

        thread.innerHTML = replies.map(renderComment).join("");
      } catch (err) {
        thread.innerHTML = '<p class="bsky-error">Could not load comments.</p>';
      }
    });
  }

  function escapeHtml(str: string): string {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  function renderComment(reply: any): string {
    const author = reply.post?.author;
    const text = escapeHtml(reply.post?.record?.text ?? "");
    const handle = escapeHtml(author?.handle ?? "unknown");
    const avatar = author?.avatar ?? "";

    return `
    <div class="bsky-comment">
        <img src="${avatar}" alt="" class="bsky-avatar" />
        <div class="bsky-comment-body">
            <span class="bsky-handle">@${handle}</span>
            <p class="bsky-text">${text}</p>
        </div>
    </div>
    `;
  }

  initBlueskyComments();
</script>
